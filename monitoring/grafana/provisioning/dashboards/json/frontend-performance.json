{
  "title": "Frontend Performance (Real User Monitoring)",
  "uid": "frontend-perf",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Avg Page Load Time (TTFB)",
      "type": "stat",
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "rate(frontend_vitals_sum{metric_name=\"TTFB\"}[5m]) / rate(frontend_vitals_count{metric_name=\"TTFB\"}[5m])", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 800 },
              { "color": "red", "value": 2000 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center"
      }
    },
    {
      "id": 2,
      "title": "Frontend Errors (Today)",
      "type": "stat",
      "gridPos": { "h": 5, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(increase(frontend_errors_total[$__range]))", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center"
      }
    },
    {
      "id": 3,
      "title": "Browser Performance Distribution",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(frontend_vitals_bucket[5m])) by (le, metric_name))", "legendFormat": "{{metric_name}} (p95)", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15
          }
        }
      }
    },
    {
      "id": 4,
      "title": "🪲 Live Frontend Error Logs (Loki)",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 14 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{ "expr": "{job=\"backend\"} |= \"frontend_error_received\"", "refId": "A" }],
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true
      }
    }
  ]
}
